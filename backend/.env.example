# Example environment variables for GRC platform backend
BASE_PORT=6000
JWT_SECRET=change_me_to_a_secure_value

# Add other variables used by your app here
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
SMTP_FROM="GRC Platform <noreply@yourdomain.com>"

# Exact frontend origin(s) allowed by CORS (use your production domain here)
FRONTEND_URL=https://grc.votre-domaine.com
CORS_ALLOWED_ORIGINS=https://grc.votre-domaine.com
# CORS_ALLOWED_ORIGIN_PATTERNS=https://*.votre-domaine.com

# Path to norms PDF files fully qualified
NORMES_PATH=C:/path/to/your/normes

# AI Configuration
PDFTOPPM_PATH=C:/poppler-25.12.0/Library/bin
OLLAMA_MODEL=llama3
# Ollama configuration (Ollama stays on the backend-side only)
# By default, Ollama URLs point to localhost:11434. Uncomment and adjust if hosted elsewhere or running on a container:
# OLLAMA_HOST=http://ollama-container-or-host:11434
# Or customize endpoints individually:
# OLLAMA_CHAT_URL=http://127.0.0.1:11434/api/chat
# OLLAMA_EMBED_URL=http://127.0.0.1:11434/api/embeddings
