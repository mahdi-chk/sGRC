# Example environment variables for GRC platform backend
BASE_PORT=6000
JWT_SECRET=change_me_to_a_secure_value

# Add other variables used by your app here
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
SMTP_FROM="GRC Platform <noreply@yourdomain.com>"

# Exact frontend origin(s) allowed by CORS
FRONTEND_URL=http://localhost:6001
# CORS_ALLOWED_ORIGINS=http://localhost:6001,https://app.example.com
# CORS_ALLOWED_ORIGIN_PATTERNS=https://*.example.com

# Path to norms PDF files fully qualified
NORMES_PATH=C:/path/to/your/normes

# AI Configuration
PDFTOPPM_PATH=C:/poppler-25.12.0/Library/bin
OLLAMA_MODEL=llama3
# OLLAMA_CHAT_URL and OLLAMA_EMBED_URL default to standard port 11434.
# OLLAMA_CHAT_URL=http://localhost:11434/api/chat
# OLLAMA_EMBED_URL=http://localhost:11434/api/embeddings
